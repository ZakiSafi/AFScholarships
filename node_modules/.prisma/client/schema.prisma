generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity & access ───────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String?
  name            String?
  role            UserRole  @default(USER)
  emailVerifiedAt DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  profile             UserProfile?
  preference          UserPreference?
  authProviders       AuthProviderAccount[]
  refreshTokens       RefreshToken[]
  sessionTokens       SessionToken[]
  passwordResetTokens PasswordResetToken[]
  savedScholarships   SavedScholarship[]
  reminders           UserReminder[]
  applications        PartnerApplication[]
  notificationLogs    NotificationLog[]
  createdScholarships Scholarship[]           @relation("ScholarshipCreator")
  submittedReports    ListingReport[]         @relation("ReportAuthor")
  reviewedReports     ListingReport[]         @relation("ReportReviewer")
  reviewedApps        PartnerApplication[]    @relation("ApplicationReviewer")
  verificationReviews VerificationReview[]
  moderationActions   ModerationActionLog[]   @relation("ModerationActor")
  attributionTouches  AttributionTouchpoint[]
  referralInvites     ReferralInvite[]        @relation("ReferralInviter")
  referredConversions ReferralConversion[]    @relation("ReferredUser")

  @@index([role])
  @@index([isActive])
}

model AuthProviderAccount {
  id                String           @id @default(uuid())
  userId            String
  provider          AuthProviderType
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SessionToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Profile & preferences ───────────────────────────────────────────────────

model UserProfile {
  userId         String       @id
  avatarUrl      String?
  bio            String?
  city           String?
  province       String?
  country        String?
  educationLevel String?
  fieldOfStudy   String?
  targetDegree   DegreeLevel?
  targetCountry  String?
  interests      String[]     @default([])
  linkedinUrl    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserPreference {
  userId                String        @id
  locale                String        @default("en")
  timezone              String        @default("UTC")
  emailDigestEnabled    Boolean       @default(true)
  marketingOptIn        Boolean       @default(false)
  preferredCountries    String[]      @default([])
  preferredDegreeLevels DegreeLevel[] @default([])
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Scholarship catalog ─────────────────────────────────────────────────────

model Scholarship {
  id                   String             @id @default(uuid())
  slug                 String             @unique
  title                String
  summary              String
  description          String
  provider             String
  hostCountry          String
  degreeLevel          DegreeLevel
  fundingType          FundingType
  languageRequirement  String?
  fieldOfStudy         String[]           @default([])
  eligibleCountries    String[]           @default([])
  minAge               Int?
  maxAge               Int?
  applicationUrl       String?
  isPartnerApplication Boolean            @default(false)
  status               ScholarshipStatus  @default(DRAFT)
  startsAt             DateTime?
  deadlineAt           DateTime
  deadlineTimezone     String             @default("UTC")
  verificationStatus   VerificationStatus @default(UNVERIFIED)
  verifiedAt           DateTime?
  lastReviewedAt       DateTime?
  isFeatured           Boolean            @default(false)
  createdById          String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  createdBy           User?                    @relation("ScholarshipCreator", fields: [createdById], references: [id], onDelete: SetNull)
  requirements        ScholarshipRequirement[]
  benefits            ScholarshipBenefit[]
  steps               ApplicationStep[]
  faqs                ScholarshipFaq[]
  sources             ScholarshipSource[]
  tags                ScholarshipToTag[]
  savedByUsers        SavedScholarship[]
  reminders           UserReminder[]
  partnerApplications PartnerApplication[]
  reports             ListingReport[]
  verificationReviews VerificationReview[]

  @@index([title])
  @@index([provider])
  @@index([hostCountry])
  @@index([deadlineAt])
  @@index([status])
  @@index([verificationStatus])
  @@index([status, createdAt])
}

model ScholarshipRequirement {
  id            String   @id @default(uuid())
  scholarshipId String
  label         String
  description   String
  orderIndex    Int
  isMandatory   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([scholarshipId, orderIndex])
}

model ScholarshipBenefit {
  id            String   @id @default(uuid())
  scholarshipId String
  title         String
  description   String
  orderIndex    Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([scholarshipId, orderIndex])
}

model ApplicationStep {
  id            String   @id @default(uuid())
  scholarshipId String
  orderIndex    Int
  title         String
  description   String
  isRequired    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([scholarshipId, orderIndex])
}

model ScholarshipFaq {
  id            String   @id @default(uuid())
  scholarshipId String
  question      String
  answer        String
  orderIndex    Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@unique([scholarshipId, orderIndex])
}

model ScholarshipSource {
  id            String    @id @default(uuid())
  scholarshipId String
  url           String
  label         String
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
}

model ScholarshipTag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  scholarships ScholarshipToTag[]
}

model ScholarshipToTag {
  scholarshipId String
  tagId         String

  scholarship Scholarship    @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  tag         ScholarshipTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([scholarshipId, tagId])
}

// ─── Student engagement ──────────────────────────────────────────────────────

model SavedScholarship {
  userId        String
  scholarshipId String
  createdAt     DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@id([userId, scholarshipId])
}

model UserReminder {
  id            String          @id @default(uuid())
  userId        String
  scholarshipId String
  reminderAt    DateTime
  channel       ReminderChannel @default(EMAIL)
  status        ReminderStatus  @default(PENDING)
  sentAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)

  @@index([reminderAt, status])
  @@index([userId])
}

model NotificationLog {
  id        String             @id @default(uuid())
  userId    String?
  type      NotificationType
  channel   ReminderChannel
  payload   Json
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?
  error     String?
  createdAt DateTime           @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([userId])
}

// ─── Application workflow ──────────────────────────────────────────────────────

model PartnerApplication {
  id             String            @id @default(uuid())
  scholarshipId  String
  userId         String
  reviewedById   String?
  fullName       String
  email          String
  phone          String?
  country        String?
  educationLevel String?
  statement      String
  docsUrls       String[]          @default([])
  status         ApplicationStatus @default(SUBMITTED)
  reviewedAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  scholarship Scholarship                   @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  user        User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy  User?                         @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  answers     PartnerApplicationAnswer[]
  statusLogs  PartnerApplicationStatusLog[]
  attachments ApplicationAttachment[]

  @@index([status, createdAt])
  @@index([userId])
}

model PartnerApplicationAnswer {
  id            String @id @default(uuid())
  applicationId String
  questionKey   String
  answer        String

  application PartnerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionKey])
}

model PartnerApplicationStatusLog {
  id            String             @id @default(uuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  note          String?
  changedById   String?
  createdAt     DateTime           @default(now())

  application PartnerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
}

model ApplicationAttachment {
  id            String   @id @default(uuid())
  applicationId String
  fileName      String
  fileUrl       String
  mimeType      String?
  sizeBytes     Int?
  uploadedAt    DateTime @default(now())

  application PartnerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ─── Trust & moderation ──────────────────────────────────────────────────────

model ListingReport {
  id            String       @id @default(uuid())
  scholarshipId String
  userId        String?
  reviewedById  String?
  reason        String
  details       String?
  status        ReportStatus @default(OPEN)
  resolvedAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  user        User?       @relation("ReportAuthor", fields: [userId], references: [id], onDelete: SetNull)
  reviewedBy  User?       @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model VerificationReview {
  id             String             @id @default(uuid())
  scholarshipId  String
  reviewerId     String
  previousStatus VerificationStatus
  newStatus      VerificationStatus
  note           String?
  createdAt      DateTime           @default(now())

  scholarship Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  reviewer    User        @relation(fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([scholarshipId, createdAt])
}

model ModerationActionLog {
  id         String   @id @default(uuid())
  actorId    String
  entityType String
  entityId   String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User @relation("ModerationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Growth analytics ────────────────────────────────────────────────────────

model AttributionTouchpoint {
  id          String   @id @default(uuid())
  userId      String?
  sessionId   String?
  source      String?
  medium      String?
  campaign    String?
  landingPath String?
  referrer    String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([sessionId])
}

model ReferralInvite {
  id            String    @id @default(uuid())
  inviterUserId String
  code          String    @unique
  email         String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  inviter     User                 @relation("ReferralInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  conversions ReferralConversion[]

  @@index([inviterUserId])
}

model ReferralConversion {
  id             String   @id @default(uuid())
  inviteId       String
  referredUserId String
  convertedAt    DateTime @default(now())

  invite       ReferralInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  referredUser User           @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([inviteId, referredUserId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum AuthProviderType {
  GOOGLE
  EMAIL
}

enum DegreeLevel {
  BACHELOR
  MASTER
  PHD
  SHORT_COURSE
}

enum FundingType {
  FULL
  PARTIAL
  TUITION_ONLY
  STIPEND_ONLY
}

enum ScholarshipStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum VerificationStatus {
  VERIFIED
  UNVERIFIED
  FLAGGED_STALE
}

enum ReminderChannel {
  EMAIL
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationType {
  REMINDER
  DIGEST
  PASSWORD_RESET
  APPLICATION_UPDATE
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}
