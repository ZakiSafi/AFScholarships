# Server
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# Database (host port 5433 when using docker-compose)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/afscholarships?schema=public"

# JWT (use strong random secrets in production)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth (optional in dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# Mail (MailHog in docker-compose)
MAIL_HOST=localhost
MAIL_PORT=1026
MAIL_FROM=noreply@afscholarships.dev
MAIL_SECURE=false

# Background jobs
JOBS_ENABLED=true
JOB_STALE_DAYS=30
